# =============================================================================
# PokéLearnOS v3 — environment configuration example
# Copy to .env and adjust. Never commit a real .env (see .gitignore).
# =============================================================================

# --- Server ---
PORT=8765
# APP_ENV=kiosk enables static frontend serving + SQLite defaults on-device.
# Leave unset (or 'development') for Replit/dev.
APP_ENV=development
NODE_ENV=development

# --- Database -----------------------------------------------------------------
# DEV / Replit  -> Postgres connection string:
#   DATABASE_URL=postgres://user:pass@host:5432/pokelearnos
#
# KIOSK / device -> local SQLite file (offline, no DB server). install.sh sets:
#   DATABASE_URL=sqlite:/home/kids/.local/share/pokelearnos/db.sqlite
#
# The driver is auto-selected from the URL scheme (sqlite: / file: / *.sqlite).
# You may also force it explicitly:
#   DB_DRIVER=sqlite
DATABASE_URL=postgres://localhost:5432/pokelearnos
# DB_DRIVER=

# --- LLM provider (optional; v1 ships disabled) -------------------------------
# One of: none | ollama | openai | anthropic | gemini
LLM_PROVIDER=none
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
